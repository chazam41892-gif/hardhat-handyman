# Image formats not allowed (iPhone formats)
*.heic
*.heif
*.HEIC
*.HEIF

# Video formats not allowed (iPhone formats)
*.hevc
*.HEVC
*.mov
*.MOV

# macOS specific files
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Node modules (if you add any build tools later)
node_modules/
npm-debug.log*

# Build outputs
dist/
build/

# Environment variables
.env
.env.local
.env.*.local

# Log files
*.log

# Temporary files
tmp/
temp/
*.tmp

# OS generated files
Thumbs.db
ehthumbs.db
